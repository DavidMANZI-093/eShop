# ── Core ─────────────────────────────────────────────────────────────────────
DATABASE_NAME="eShop.db"
DEFAULT_ADMIN_USER="eShopAdmin"
DEFAULT_ADMIN_EMAIL="admin@eShop.com"
DEFAULT_ADMIN_NAME="Admin At eShop"
DEFAULT_ADMIN_PASS="change-me-in-production"
DEFAULT_USER_AVATAR="data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHZpZXdCb3g9Ii00IC00IDMyIDMyIiB3aWR0aD0iNjQiIGhlaWdodD0iNjQiIGZpbGw9IiNhOGE4YTgiPjxwYXRoIGQ9Ik0xMiAxMmE1IDUgMCAxIDAgMC0xMCA1IDUgMCAwIDAgMCAxMHptMCAyYy00LjQyIDAtOCAzLjU4LTggOHYxaDE2di0xYzAtNC40Mi0zLjU4LTgtOC04eiIvPjwvc3ZnPg=="
APP_SECRET="generate-a-64-char-hex-secret-here"

# ── URL ──────────────────────────────────────────────────────────────────────
# Absolute base URL used to build links inside emails. No trailing slash.
# Development default: http://localhost:5000
BASE_URL="http://localhost:5000"

# ── Mail (SMTP) ───────────────────────────────────────────────────────────────
# Leave MAIL_SERVER blank to use the dev console fallback (emails print to stdout).
#
# Gmail example:
#   MAIL_SERVER=smtp.gmail.com
#   MAIL_PORT=587
#   MAIL_USE_TLS=true
#   MAIL_USERNAME=you@gmail.com
#   MAIL_PASSWORD=<16-char app password>
#   Generate an App Password at: https://myaccount.google.com/apppasswords
#   (requires 2-Step Verification to be enabled on the Google account)
MAIL_SERVER=""
MAIL_PORT="587"
MAIL_USE_TLS="true"
MAIL_USERNAME=""
MAIL_PASSWORD=""
MAIL_FROM="noreply@eshop.com"

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Leave blank to disable the "Continue with Google" button entirely.
#
# Setup:
#   1. Go to https://console.cloud.google.com and create a project.
#   2. APIs & Services → Credentials → Create Credentials → OAuth 2.0 Client ID
#   3. Application type: Web application
#   4. Add Authorized redirect URI:
#        http://localhost:5000/auth/google/callback       (development)
#        https://yourdomain.com/auth/google/callback      (production)
#   5. Copy the Client ID and Client Secret below.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
